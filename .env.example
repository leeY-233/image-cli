OPENAI_API_KEY=sk-your-provider-key
OPENAI_BASE_URL=https://api.your-provider.example/v1
IMAGE_PROVIDERS=[{"id":"default","name":"Default Provider","base_url":"https://api.your-provider.example/v1","api_key":"sk-your-provider-key","note":"Default provider remark shown on homepage hover"}]
IMAGE_MODEL=gpt-image-2

# Optional defaults
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=auto
IMAGE_OUTPUT_FORMAT=png
IMAGE_RESPONSE_FORMAT=b64_json
IMAGE_EDIT_IMAGE_FIELD=image[]
OUTPUT_DIR=outputs
LOG_DIR=logs
REQUEST_TIMEOUT_SECONDS=600
PROVIDER_MAX_ATTEMPTS=2
HISTORY_LIMIT=50
MAX_ACTIVE_JOBS=10
APP_PASSWORD=change-this-password
ADMIN_PASSWORD=change-this-admin-password
APP_SESSION_SECRET=change-this-random-secret
SYSTEMD_UNIT=image-cli
