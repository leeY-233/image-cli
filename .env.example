OPENAI_API_KEY=sk-your-provider-key
OPENAI_BASE_URL=https://api.your-provider.example/v1
IMAGE_PROVIDERS=[{"id":"default","name":"Default Provider","generate_mode":"generate","edit_mode":"edit","base_url":"https://api.your-provider.example/v1","api_key":"sk-your-provider-key","generate_model":"your-generate-model","edit_model":"your-edit-model","note":"Default provider remark shown on homepage hover"},{"id":"chat-image","name":"Chat Completions Image","generate_mode":"completions","edit_mode":"completions","base_url":"https://api.chat-image-provider.example/v1","api_key":"sk-your-chat-provider-key","generate_model":"your-chat-generate-model","edit_model":"your-chat-edit-model","note":"Generate/Edit use /v1/chat/completions."}]
IMAGE_MODEL=gpt-image-2

# Optional defaults
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=auto
IMAGE_OUTPUT_FORMAT=png
IMAGE_RESPONSE_FORMAT=b64_json
IMAGE_EDIT_IMAGE_FIELD=image[]
OUTPUT_DIR=outputs
LOG_DIR=logs
REQUEST_TIMEOUT_SECONDS=600
PROVIDER_MAX_ATTEMPTS=2
HISTORY_LIMIT=50
MAX_ACTIVE_JOBS=10
APP_PASSWORD=change-this-password
ADMIN_PASSWORD=change-this-admin-password
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SESSION_SECRET=replace-with-token-urlsafe-48-output
SYSTEMD_UNIT=image-cli
DEBUG_LOG_SERVICES=[{"name":"Image CLI","type":"systemd","target":"image-cli","enabled":true},{"name":"Chat API","type":"docker","target":"grok2api","enabled":true},{"name":"Proxy API","type":"systemd","target":"cliproxyapi.service","enabled":true},{"name":"Spare","type":"systemd","target":"","enabled":false}]
